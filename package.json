{
  "name": "nc-mcp-server",
  "version": "2.1.0",
  "description": "MCP Server for N-central REST API — exposes all GET endpoints as MCP tools with org hierarchy resources and workflow prompts.",
  "type": "module",
  "private": true,
  "main": "index.js",
  "bin": {
    "nc-mcp-server": "./index.js"
  },
  "scripts": {
    "start": "node --env-file-if-exists=.env index.js",
    "start:stdio": "node --env-file-if-exists=.env index.js",
    "start:http": "MCP_PORT=3100 node --env-file-if-exists=.env index.js",
    "test": "node --test test/*.test.js",
    "lint": "eslint .",
    "type-check": "tsc -p tsconfig.json"
  },
  "engines": {
    "node": ">=22.9.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.21",
    "eslint": "^10.5.0",
    "eslint-plugin-n": "^18.1.0",
    "globals": "^17.6.0",
    "typescript": "^6.0.3"
  }
}
