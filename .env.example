# N-central MCP Server Configuration
# Copy this file to .env and fill in the values.

# REQUIRED: N-central server URL
NC_SERVER_URL=https://ncentral.example.com

# REQUIRED: User-API JWT token from N-central UI
NC_JWT_TOKEN=your-jwt-token-here

# OPTIONAL: Which tools to expose (default: write)
#   read-only  — only GET endpoints
#   write      — GET + create/update (POST/PUT/PATCH) tools
#   full       — all of the above + destructive tools (DELETE device,
#                DELETE maintenance windows, direct script execution)
NC_WRITE_MODE=write

# RECOMMENDED: API key for MCP HTTP endpoint authentication
# Generate a strong random key: openssl rand -hex 32
# Clients must pass this as: Authorization: Bearer <key>
MCP_API_KEY=

# OPTIONAL: Allowed CORS origin (leave empty to disable CORS)
# Example: http://localhost:3000
MCP_CORS_ORIGIN=

# OPTIONAL: Bind address (default: 127.0.0.1, use 0.0.0.0 for Docker)
MCP_BIND_ADDRESS=127.0.0.1

# OPTIONAL: HTTP port for Streamable HTTP mode (omit for stdio mode)
MCP_PORT=3100